#!/usr/bin/env bash
set -euo pipefail

mkdir -p "${APP_DATA_DIR}/data/beets"
mkdir -p "${APP_DATA_DIR}/data/backup"
mkdir -p "${APP_DATA_DIR}/data/home"
mkdir -p "${APP_DATA_DIR}/data/cache"
mkdir -p "${APP_DATA_DIR}/data/poetry-cache"
mkdir -p "${APP_DATA_DIR}/config/beets"

if [[ ! -f "${APP_DATA_DIR}/config/beets/config.yaml" ]]; then
cat > "${APP_DATA_DIR}/config/beets/config.yaml" << 'EOF'
directory: /music
library: /data/beets/library.db
import:
  copy: no
  move: no
  write: no
  autotag: no
  log: /data/beets/beetslog.txt
ui:
  color: yes
pluginpath:
  - src/beetsplug
plugins: duplicates duplicatez info
duplicates:
  format: $mb_trackid - $mb_albumid | $path
  keys: [mb_trackid, mb_albumid]
  full: yes
  strict: yes
  album: no
  count: no
  delete: no
  path: no
  group: no
autobpm:
  auto: yes
  overwrite: no
  beat_track_kwargs:
    start_bpm: 160
EOF
fi

chown -R 1000:1000 "${APP_DATA_DIR}/data" "${APP_DATA_DIR}/config"

echo "Navidrome Toolbox: app data initialized."
