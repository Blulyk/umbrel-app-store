#!/usr/bin/env bash
set -euo pipefail

mkdir -p "${APP_DATA_DIR}/data"
mkdir -p "${APP_DATA_DIR}/config"

cat > "${APP_DATA_DIR}/config/cors.ini" << 'EOF'
[cors]
origins = *
credentials = true
methods = GET, PUT, POST, HEAD, DELETE
headers = accept, authorization, content-type, origin, referer, x-csrf-token
max_age = 3600

[chttpd]
bind_address = any

[httpd]
enable_cors = true
EOF

echo "LiveSync: CORS config aplicada."
