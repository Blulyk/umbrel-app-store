#!/usr/bin/env bash
set -euo pipefail

DATA_DIR="${APP_DATA_DIR}/data"
SOURCE_DIR="${DATA_DIR}/source"
ENV_FILE="${SOURCE_DIR}/.env"

mkdir -p \
  "${SOURCE_DIR}" \
  "${DATA_DIR}/ssh/keys" \
  "${DATA_DIR}/ssh/mux" \
  "${DATA_DIR}/ssh" \
  "${DATA_DIR}/applications" \
  "${DATA_DIR}/databases" \
  "${DATA_DIR}/services" \
  "${DATA_DIR}/backups" \
  "${DATA_DIR}/postgres" \
  "${DATA_DIR}/redis"

HOST_PRIVATE_KEY="${DATA_DIR}/ssh/keys/id.root@host.docker.internal"
HOST_PUBLIC_KEY="${HOST_PRIVATE_KEY}.pub"

if [[ ! -f "${HOST_PRIVATE_KEY}" ]]; then
  ssh-keygen -t ed25519 -N "" -C "coolify-generated-ssh-key" -f "${HOST_PRIVATE_KEY}"
fi

chmod 700 "${DATA_DIR}/ssh" "${DATA_DIR}/ssh/keys" "${DATA_DIR}/ssh/mux"
chmod 600 "${HOST_PRIVATE_KEY}"
chmod 644 "${HOST_PUBLIC_KEY}"

if [[ -f "${HOST_PUBLIC_KEY}" && -d /root ]]; then
  mkdir -p /root/.ssh
  chmod 700 /root/.ssh
  touch /root/.ssh/authorized_keys
  if ! grep -qxF "$(cat "${HOST_PUBLIC_KEY}")" /root/.ssh/authorized_keys; then
    cat "${HOST_PUBLIC_KEY}" >> /root/.ssh/authorized_keys
    printf "\n" >> /root/.ssh/authorized_keys
  fi
  chmod 600 /root/.ssh/authorized_keys
fi

chown -R 9999:9999 \
  "${SOURCE_DIR}" \
  "${DATA_DIR}/ssh" \
  "${DATA_DIR}/applications" \
  "${DATA_DIR}/databases" \
  "${DATA_DIR}/services" \
  "${DATA_DIR}/backups"

random_hex() {
  openssl rand -hex 32
}

random_base64() {
  openssl rand -base64 32
}

if [[ ! -f "${ENV_FILE}" ]]; then
  db_password="$(random_hex)"
  redis_password="$(random_hex)"
  pusher_app_id="$(random_hex)"
  pusher_app_key="$(random_hex)"
  pusher_app_secret="$(random_hex)"

  cat > "${ENV_FILE}" << EOF
APP_ID=$(random_hex)
APP_NAME=Coolify
APP_KEY=base64:$(random_base64)
APP_ENV=production
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=coolify
DB_USERNAME=coolify
DB_PASSWORD=${db_password}
POSTGRES_PASSWORD=${db_password}

REDIS_HOST=redis
REDIS_PASSWORD=${redis_password}
REDIS_PORT=6379

PUSHER_APP_ID=${pusher_app_id}
PUSHER_APP_KEY=${pusher_app_key}
PUSHER_APP_SECRET=${pusher_app_secret}
PUSHER_HOST=
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_BACKEND_HOST=soketi
PUSHER_BACKEND_PORT=6001
SOKETI_DEFAULT_APP_ID=${pusher_app_id}
SOKETI_DEFAULT_APP_KEY=${pusher_app_key}
SOKETI_DEFAULT_APP_SECRET=${pusher_app_secret}

REGISTRY_URL=docker.io
EOF
  chmod 600 "${ENV_FILE}"
  echo "Coolify: generated persistent environment file."
else
  echo "Coolify: existing environment file found."
fi
